# Production environment for docker-compose-prod.yml
# Copy to .env.prod and fill in real values:
#   cp .env.prod.example .env.prod
# Then deploy with:
#   docker compose --env-file .env.prod -f docker-compose-prod.yml up -d
#
# NOTE: .env.prod is gitignored. Never commit real secrets.

# Public fully-qualified domain name (NOT an IP). Browsers send SNI for an FQDN,
# so the dev-only Caddy "default_sni" / "tls internal" workaround is not needed here.
CISO_FQDN=grc.example.com

# Absolute paths ON THE HOST to your corporate/custom certificate and private key.
# These are mounted read-only into the caddy container as /etc/caddy/cert.pem and key.pem.
# CERT_PATH should be the full chain (server cert + intermediates).
CERT_PATH=/etc/ssl/ciso/fullchain.pem
KEY_PATH=/etc/ssl/ciso/privkey.pem

# PostgreSQL database settings.
POSTGRES_NAME=ciso-assistant
POSTGRES_USER=ciso
POSTGRES_PASSWORD=change-me

# Fixed Django secret key (REQUIRED in production so sessions survive restarts).
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=generate-a-long-random-string
