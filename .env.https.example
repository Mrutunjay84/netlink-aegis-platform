# Self-signed HTTPS deployment for docker-compose-https.yml  (encrypted, no purchased certs)
# Copy to .env.https and set the value below:
#   cp .env.https.example .env.https
# Then deploy:
#   docker compose --env-file .env.https -f docker-compose-https.yml up -d --build
#
# NOTE: .env.https is gitignored.

# This host's IP address or hostname, as typed in the browser (no https://, no port).
# You then reach the app at  https://<this value>/  and accept the one-time
# "not private -> proceed" browser warning (expected with a self-signed cert).
# Examples:  192.168.1.50   or   grc.internal.lan
CISO_FQDN=192.168.1.50

# Optional first-boot admin account. If you set BOTH of these, the admin user is
# created automatically the first time the stack starts (no manual createsuperuser
# step). Leave them commented to create the admin manually instead.
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=change-me-strong

# Optional: lower this if the build host has little RAM (frontend build memory, MB).
# NODE_BUILD_HEAP_MB=6144
