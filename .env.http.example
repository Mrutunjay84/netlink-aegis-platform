# Plain-HTTP deployment for docker-compose-http.yml  (NO TLS - unencrypted)
# Copy to .env.http and set the value below:
#   cp .env.http.example .env.http
# Then deploy:
#   docker compose --env-file .env.http -f docker-compose-http.yml up -d --build
#
# NOTE: .env.http is gitignored.

# This host's IP address or hostname, as typed in the browser (no http://, no port).
# Examples:  192.168.1.50   or   grc.internal.lan
CISO_FQDN=192.168.1.50

# Optional first-boot admin account. If you set BOTH of these, the admin user is
# created automatically the first time the stack starts (no manual createsuperuser
# step). Leave them commented to create the admin manually instead.
# DJANGO_SUPERUSER_EMAIL=admin@example.com
# DJANGO_SUPERUSER_PASSWORD=change-me-strong

# Optional: lower this if the build host has little RAM (frontend build memory, MB).
# NODE_BUILD_HEAP_MB=6144
